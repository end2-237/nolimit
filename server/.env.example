# ═══════════════════════════════════════════════════════════════════════════════
# NoLimit Stock API Server - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server Configuration ──────────────────────────────────────────────────────

# Server port
PORT=3001

# Environment: development | production | staging
NODE_ENV=development

# ─── Database (PostgreSQL / Neon) ──────────────────────────────────────────────

# Local PostgreSQL (Development):
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/nolimit
#
# Neon Cloud (Production - Recommended):
#   DATABASE_URL=postgresql://user:password@[region].neon.tech/nolimit?sslmode=require
#
# Connection pooling is handled automatically by the server
DATABASE_URL=postgresql://user:password@host:5432/nolimit

# ─── Security ──────────────────────────────────────────────────────────────────

# JWT Secret for token signing (generate with: openssl rand -base64 32)
# IMPORTANT: Change this in production!
# Never commit the actual secret - use Render secrets instead
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# ─── Frontend Integration (CORS) ───────────────────────────────────────────────

# Frontend URL for CORS configuration
# Development: http://localhost:5173
# Production: https://your-domain.com
FRONTEND_URL=http://localhost:5173

# ─── Logging ───────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ─── Sync Configuration (Hybrid Mode) ──────────────────────────────────────────

# Maximum records per sync push (prevents memory overflow)
MAX_SYNC_BATCH=10000

# Sync request timeout in milliseconds
SYNC_TIMEOUT=30000

# ─── Rate Limiting ────────────────────────────────────────────────────────────

# Rate limit for sync endpoints (requests per minute)
SYNC_RATE_LIMIT=100

# Rate limit for general endpoints (requests per minute)
GENERAL_RATE_LIMIT=1000

# ─── Database Connection Pool ────────────────────────────────────────────────

# Minimum connections to maintain
DB_POOL_MIN=2

# Maximum connections (Neon Starter plan max: 50)
DB_POOL_MAX=20

# Idle connection timeout (milliseconds)
DB_IDLE_TIMEOUT=30000

# ─── WebSocket Configuration ──────────────────────────────────────────────────

# WebSocket ping interval (milliseconds)
WS_PING_INTERVAL=30000

# WebSocket connection timeout (milliseconds)
WS_TIMEOUT=60000
