{
  "appId": "com.nolimit.stock",
  "productName": "Stock No Limit",
  "copyright": "Copyright © 2025 No Limit Enterprise",
  "directories": {
    "output": "release",
    "buildResources": "public/icons"
  },
  "files": [
    "dist/**/*",
    "dist-electron/**/*",
    "public/**/*",
    "!node_modules/**/*",
    "!src/**/*",
    "!electron/**/*",
    "!server/**/*",
    "!release/**/*",
    "!*.md",
    "!*.log"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icons/icon.ico",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "requestedExecutionLevel": "asInvoker"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowElevation": true,
    "allowToChangeInstallationDirectory": true,
    "installerIcon": "public/icons/icon.ico",
    "uninstallerIcon": "public/icons/icon.ico",
    "installerHeaderIcon": "public/icons/icon.ico",
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Stock No Limit",
    "displayLanguageSelector": false,
    "language": "1036",
    "runAfterFinish": true,
    "deleteAppDataOnUninstall": false,
    "include": null
  },
  "mac": {
    "target": ["dmg"],
    "icon": "public/icons/icon.icns",
    "category": "public.app-category.business",
    "artifactName": "${productName}-${version}.${ext}"
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "public/icons",
    "category": "Office",
    "artifactName": "${productName}-${version}.${ext}"
  },
  "publish": null
}