# ═══════════════════════════════════════════════════════════════════════════════
# SNL Backend — Variables d'environnement pour Coolify
# ═══════════════════════════════════════════════════════════════════════════════
#
# Dans Coolify :
#   1. Ton service → Environment Variables
#   2. Coller chaque variable ci-dessous avec sa vraie valeur
#   3. Redéployer
#
# Sur chaque machine Electron (Settings > Cloud & Sync) :
#   URL API : https://ton-domaine-coolify.com/api/sync
#   SOCKET_SECRET : même valeur qu'ici
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Serveur ──────────────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Adresses autorisées à se connecter (IP ou domaines des machines Electron)
# Pour réseau interne uniquement → utiliser * (plus simple)
# Pour sécuriser → lister les IPs : http://192.168.1.10,http://192.168.1.11
FRONTEND_URL=*

# ─── Sécurité Socket.io ───────────────────────────────────────────────────────
# Secret partagé entre le backend et les apps Electron
# Générer avec : openssl rand -hex 32
# ⚠️ Même valeur à mettre dans la config Electron de CHAQUE machine
SOCKET_SECRET=CHANGE_ME_openssl_rand_hex_32

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Générer avec : openssl rand -base64 64
JWT_SECRET=CHANGE_ME_openssl_rand_base64_64

# ─── Base de données (optionnel) ──────────────────────────────────────────────
# L'app fonctionne sans — chaque Electron garde ses données en local
# Si tu veux de la persistance côté serveur :
# DATABASE_URL=postgresql://user:password@host:5432/nolimit

# ─── Logs ────────────────────────────────────────────────────────────────────
LOG_LEVEL=info


# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURATION CÔTÉ ELECTRON (dans l'app, Settings > Cloud & Sync)
# ═══════════════════════════════════════════════════════════════════════════════
#
# URL API    : https://TON_DOMAINE_COOLIFY/api/sync
# API Key    : (laisser vide ou mettre n'importe quoi)
# Site ID    : DLA (ou l'ID du site de cette machine)
#
# Le SOCKET_SECRET est automatiquement lu depuis la config cloud.
# L'URL du serveur WebSocket est extraite de l'URL API.
#
# ═══════════════════════════════════════════════════════════════════════════════
# CONFIGURATION CÔTÉ ELECTRON via variables d'environnement (optionnel)
# ─────────────────────────────────────────────────────────────────────────────
# Si tu veux hardcoder dans un .env local sur chaque machine Electron :
#
# VITE_API_URL=https://TON_DOMAINE_COOLIFY
# VITE_WS_URL=https://TON_DOMAINE_COOLIFY
# VITE_SOCKET_SECRET=MEME_VALEUR_QUE_SOCKET_SECRET_CI_DESSUS
# ═══════════════════════════════════════════════════════════════════════════════
