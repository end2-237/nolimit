# ── Stage 1: Build ────────────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /app

# Install pnpm via corepack (built into Node 22)
RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

# Copy manifests first for layer caching
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

# Install deps (skip electron binary download)
RUN ELECTRON_SKIP_BINARY_DOWNLOAD=1 pnpm install --frozen-lockfile

# Copy source
COPY . .

# Build args baked into the static bundle at build time
ARG VITE_API_URL=https://snl-api.vps.buyticle.com/api
ARG VITE_WS_URL=https://snl-api.vps.buyticle.com
ARG VITE_SOCKET_SECRET=
ARG VITE_API_KEY=
ARG VITE_VITRINE_URL=https://nolimitvitrine.vps.buyticle.com
ARG VITE_SITE_ADMIN_KEY=

ENV VITE_API_URL=$VITE_API_URL \
    VITE_WS_URL=$VITE_WS_URL \
    VITE_SOCKET_SECRET=$VITE_SOCKET_SECRET \
    VITE_API_KEY=$VITE_API_KEY \
    VITE_VITRINE_URL=$VITE_VITRINE_URL \
    VITE_SITE_ADMIN_KEY=$VITE_SITE_ADMIN_KEY

RUN pnpm build:web

# ── Stage 2: Serve ────────────────────────────────────────────────────────────
FROM nginx:alpine AS runner

COPY --from=builder /app/dist-web /usr/share/nginx/html

# SPA config: all routes → index.html
RUN printf 'server {\n\
    listen 80;\n\
    root /usr/share/nginx/html;\n\
    index index.html;\n\
    gzip on;\n\
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml text/javascript;\n\
    location ~* \\.(js|css|png|jpg|ico|svg|woff2|woff|ttf|eot)$ {\n\
        expires 1y;\n\
        add_header Cache-Control "public, immutable";\n\
    }\n\
    location / {\n\
        try_files $uri $uri/ /index.html;\n\
    }\n\
}\n' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
